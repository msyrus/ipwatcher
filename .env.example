# ipwatcher environment variables
#
# Fill in only the provider credentials you need.
# The systemd service reads this file from /opt/ipwatcher/.env after installation.

# Cloudflare
CLOUDFLARE_API_TOKEN=

# AWS Route 53 (standard AWS SDK environment variables)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Optional: override the config file path when running manually.
# CONFIG_FILE=config.yaml
